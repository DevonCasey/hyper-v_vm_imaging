# -*- mode: ruby -*-
# vi: set ft=ruby :

# Enhanced Barebones Windows Server 2025 Environment
# Version: 2.0.0

# Load shared configuration
require_relative '../shared/common'

Vagrant.configure("2") do |config|
  # Initialize configuration helper
  config_helper = VagrantConfig.new("barebones")
  
  # Validate that the golden image exists
  validate_box_exists(config_helper.golden_image_box)
  
  # Get VM configuration (interactive if requested)
  vm_config = get_vm_configuration("barebones", config_helper)
  
  # Apply common VM settings
  configure_common_vm_settings(config, vm_config, config_helper)
  
  # Configure Hyper-V provider
  configure_hyperv_provider(config, vm_config, config_helper)
  
  # Configure data drive creation trigger
  configure_data_drive_trigger(config, vm_config)
  
  # Base system configuration
  config.vm.provision "powershell", 
    inline: get_base_provisioning_script(vm_config, config_helper),
    env: {
      "DRIVE_LETTER" => vm_config[:drive_letter],
      "DRIVE_NAME" => vm_config[:drive_name]
    }
  
  # Install Windows Updates
  config.vm.provision "powershell", inline: get_windows_updates_script
  
  # Final status report
  config.vm.provision "powershell", 
    inline: get_status_report_script(vm_config, config_helper, "Barebones Windows Server 2025"),
    env: {
      "DRIVE_LETTER" => vm_config[:drive_letter],
      "DRIVE_NAME" => vm_config[:drive_name]
    }
end